DATABASE_URL=sqlite:///./za_company.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

# Timezone the business operates in — staff "today" cutoffs are computed against this,
# not the server host's clock. Defaults to Asia/Manila if unset.
APP_TIMEZONE=Asia/Manila

ADMIN_EMAIL=admin@za-company.com
ADMIN_PASSWORD=change-me

# Comma-separated frontend origins allowed to call this API. "*" (default) is fine for local dev.
# In production, set to your Vercel URL, e.g. https://za-company.vercel.app
CORS_ORIGINS=*

# Enables /docs, /redoc, and /openapi.json. Leave unset (false) in production.
DEBUG=false
